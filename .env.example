# -----------------------------
# LLM / AI Providers
# -----------------------------

# OpenAI API Key (Required for Extraction & Reasoning)
OPENAI_API_KEY=your-openai-api-key-here

# Google Gemini API Key (Optional / Future use)
GEMINI_API_KEY=your-gemini-api-key-here

# -----------------------------
# Infrastructure / Backend
# -----------------------------

# FastAPI CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Database (Production uses PostgreSQL)
# DATABASE_URL=postgresql+psycopg2://complyt:complyt@postgres:5432/complyt

# Redis / Celery (Task Queue)
# If running locally without docker, use redis://localhost:6379/0
REDIS_URL=redis://redis:6379/0

# File Storage
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_BYTES=26214400

# -----------------------------
# Security
# -----------------------------

# JWT Authentication
JWT_SECRET_KEY=generate-a-long-secure-random-string-here
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# Session Secret (Optional: Fallbacks to JWT_SECRET_KEY)
SESSION_SECRET_KEY=another-secure-random-string

# Fernet Encryption Key (Optional: Auto-derived if omitted)
# FERNET_KEY=base64-url-safe-32-byte-key
