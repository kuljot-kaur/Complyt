# Google Gemini API Key
# Get your key from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your-api-key-here

# Optional: Temp directory for files (default: /tmp/complyt)
# TEMP_DIR=/tmp/complyt

# Optional: Log directory (default: /tmp/complyt_logs)
# LOG_DIR=/tmp/complyt_logs

# -----------------------------
# Person B - API / Infra
# -----------------------------

# FastAPI CORS
ALLOWED_ORIGINS=http://localhost:3000

# PostgreSQL (prod) - dev fallback can stay sqlite if unset
# DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/complyt

# Redis/Celery
REDIS_URL=redis://localhost:6379/0

# Upload storage
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_BYTES=26214400

# JWT Auth
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# Fernet (optional; auto-derived from JWT secret if omitted)
# FERNET_KEY=base64-url-safe-32-byte-key
